# ═══════════════════════════════════════
#  BACKEND — .env
#  Copia este archivo como .env y rellena
# ═══════════════════════════════════════

# Server
PORT=5000
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/romans_db

# JWT
JWT_SECRET=your_super_secret_key_change_in_production_min_32_chars
JWT_EXPIRES_IN=7d

# CORS
FRONTEND_URL=http://localhost:5173

# Uploads (Cloudinary o local)
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760
